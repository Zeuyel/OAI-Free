# 必填：数据库连接（优先 DATABASE_URL）
# Supabase 直连（IPv6 环境）：
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Supabase pooler（推荐，IPv4 友好）：
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&default_query_exec_mode=simple_protocol
# 也可以改用 SUPABASE_DB_URL（当 DATABASE_URL 为空时读取）
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&default_query_exec_mode=simple_protocol
GO_TEAM_API_ADDR=127.0.0.1:18081
API_KEYS=admin:change-admin-key,operator:change-operator-key,viewer:change-viewer-key
GO_TEAM_API_WEB_DIR=./web
MAIL_FETCH_VIEWER_PATH=./web/mail_fetch_viewer.html

# 连接池（可选）
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SECONDS=1800
DB_CONN_MAX_IDLE_TIME_SECONDS=600
